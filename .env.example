# =============================================================================
# ForkCart Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Database
# ⚠️  RVS-015: CHANGE THESE CREDENTIALS IN PRODUCTION!
# Generate a secure password: openssl rand -base64 32
POSTGRES_USER=forkcart
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD
POSTGRES_DB=forkcart
DATABASE_URL=postgresql://forkcart:CHANGE_ME_GENERATE_SECURE_PASSWORD@localhost:5432/forkcart

# API Server
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session
# ⚠️  RVS-014: REQUIRED - Generate a secure secret: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# Admin Panel
NEXT_PUBLIC_API_URL=http://localhost:4000

# Storefront
NEXT_PUBLIC_STOREFRONT_API_URL=http://localhost:4000

# AI Providers (optional — configure the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Stripe (optional — for payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Media Storage
MEDIA_STORAGE_PATH=./uploads
MEDIA_BASE_URL=http://localhost:4000/uploads

# Cache Revalidation (storefront <-> API)
# Generate with: openssl rand -base64 32
# Required in production for cache invalidation to work
REVALIDATE_SECRET=

# Plugin Secrets Encryption
# Required for encrypting plugin secrets (generate with: openssl rand -hex 32)
FORKCART_ENCRYPTION_KEY=

# Logging
LOG_LEVEL=info

# Plugin Registry (optional — enables Plugin Marketplace)
# Leave empty for offline/air-gapped mode with manual plugin installation
PLUGIN_REGISTRY_URL=https://developers.forkcart.com/api/v1
