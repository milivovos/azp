{
  "name": "forkcart",
  "version": "0.1.2",
  "private": true,
  "description": "The AI-native e-commerce platform",
  "license": "MIT",
  "homepage": "https://github.com/forkcart/forkcart#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/forkcart/forkcart.git"
  },
  "bugs": {
    "url": "https://github.com/forkcart/forkcart/issues"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency 15",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @forkcart/database generate",
    "db:migrate": "pnpm --filter @forkcart/database migrate",
    "db:seed": "pnpm --filter @forkcart/database seed",
    "db:studio": "pnpm --filter @forkcart/database studio",
    "installer": "pnpm --filter @forkcart/installer start",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  }
}
