{
  "name": "@forkcart/core",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@forkcart/ai": "workspace:*",
    "@forkcart/database": "workspace:*",
    "@forkcart/i18n": "workspace:*",
    "@forkcart/shared": "workspace:*",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "stripe": "^21.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
