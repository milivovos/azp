    "test:watch": "vitest"
  },
  "dependencies": {
    "@forkcart/shared": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
