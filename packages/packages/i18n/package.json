{
  "name": "@forkcart/i18n",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./locales/en": "./locales/en.json",
    "./locales/de": "./locales/de.json",
    "./locales/admin-en": "./locales/admin-en.json",
    "./locales/admin-de": "./locales/admin-de.json",
    "./generated": {
      "types": "./dist/_locales.generated.d.ts",
      "import": "./dist/_locales.generated.js"
    }
  },
  "scripts": {
    "build": "node scripts/build-locales.js && tsc",
    "generate": "node scripts/build-locales.js",
    "dev": "node scripts/build-locales.js && tsc --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  }
}
