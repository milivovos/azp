{
  "name": "@forkcart/storefront",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/next-dev-port.cjs",
    "build": "next build",
    "start": "next start --port ${STOREFRONT_PORT:-4200}",
